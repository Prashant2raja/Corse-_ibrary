{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Course Library: Run",
      "type": "shell",
      "command": "${workspaceFolder}\\mvnw.cmd",
      "args": [
        "spring-boot:run"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "Course Library: Package",
      "type": "shell",
      "command": "${workspaceFolder}\\mvnw.cmd",
      "args": [
        "clean",
        "package"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    }
  ]
}
